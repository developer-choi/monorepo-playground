{
  "extends": ["stylelint-config-standard-scss"],
  "plugins": ["stylelint-declaration-strict-value"],
  "rules": {
    "at-rule-disallowed-list": ["import"],
    "selector-class-pattern": [
      "^[a-z][a-zA-Z0-9]*$",
      {"message": "클래스명은 camelCase만 허용합니다 (예: buttonPrimary)"}
    ],
    "selector-pseudo-class-no-unknown": [true, {"ignorePseudoClasses": ["global"]}],
    "scss/at-mixin-pattern": [
      "^_?[a-z][a-zA-Z0-9]*$",
      {"message": "mixin 이름은 camelCase만 허용합니다 (예: flexCenter). _ prefix는 SCSS private 관례로 허용"}
    ],
    "scss/dollar-variable-pattern": null,
    "scss/at-function-pattern": [
      "^_?[a-z][a-zA-Z0-9]*$",
      {"message": "function 이름은 camelCase만 허용합니다 (예: safeMapGet). _ prefix는 SCSS private 관례로 허용"}
    ],
    "scss/at-use-no-unnamespaced": true,
    "value-keyword-case": null,
    "scale-unlimited/declaration-strict-value": [
      [
        "/color$/",
        "background",
        "outline",
        "box-shadow",
        "text-shadow",
        "font-size",
        "line-height",
        "padding",
        "padding-top",
        "padding-right",
        "padding-bottom",
        "padding-left",
        "margin",
        "margin-top",
        "margin-right",
        "margin-bottom",
        "margin-left",
        "width",
        "height",
        "min-width",
        "min-height",
        "max-width",
        "max-height"
      ],
      {
        "ignoreValues": [
          "0",
          "auto",
          "inherit",
          "initial",
          "unset",
          "normal",
          "none",
          "transparent",
          "currentColor",
          "/^var\\(/",
          "100%",
          "/^calc\\(/"
        ],
        "ignoreFunctions": false,
        "expandShorthand": true,
        "recurseLonghand": true
      }
    ]
  }
}
