{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* TP에서 검증한 안전망 옵션 */
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true
  }
}
